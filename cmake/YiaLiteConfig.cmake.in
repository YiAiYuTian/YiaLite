@PACKAGE_INIT@

# YiaLite is a shared library (DLL). All third-party dependencies
# (SDL3, spdlog, vorbis, ogg) are statically linked inside YiaLite.dll.
# Consumers only need YiaLite.lib (import lib) — no extra find_dependency calls.

include("${CMAKE_CURRENT_LIST_DIR}/YiaLiteTargets.cmake")

check_required_components(YiaLite)
